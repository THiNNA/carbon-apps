# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=carbon_footprint_db
MYSQL_USER=db_admin
MYSQL_PASSWORD=change_me_db_password

# API — DATABASE_URL ต้อง URL-encode @ เป็น %40 ใน password
# ถ้า password คือ "myPass@123" → "myPass%40123"
DATABASE_URL=mysql://db_admin:change_me_db_password@db:3306/carbon_footprint_db

# JWT
JWT_SECRET=change_me_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars

# CORS (CORS_ORIGIN=http://localhost:5173 หรือระบุ URL จริงของแอปหน้าบ้าน เช่น https://app.carbon-footprint.com)
CORS_ORIGIN=http://localhost:5173
